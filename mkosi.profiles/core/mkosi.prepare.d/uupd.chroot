#!/bin/bash

set -ouex pipefail

echo "Downloading and installing uupd binary..."
curl -sL https://github.com/ublue-os/uupd/releases/download/v1.3.0/uupd_Linux_x86_64.tar.gz | tar -xz --no-same-owner uupd
install -Dm755 -t "/usr/bin" uupd
rm -f uupd

echo "Fetching config.json..."
curl -sL https://raw.githubusercontent.com/ublue-os/uupd/refs/heads/main/config.json | install -Dm644 /dev/stdin "/etc/uupd/config.json"

echo "Fetching uupd.service..."
curl -sL https://raw.githubusercontent.com/ublue-os/uupd/refs/heads/main/uupd.service | install -Dm644 /dev/stdin "/usr/lib/systemd/system/uupd.service"
curl -sL https://raw.githubusercontent.com/ublue-os/uupd/refs/heads/main/uupd.timer | install -Dm644 /dev/stdin "/usr/lib/systemd/system/uupd.timer"
curl -sL https://raw.githubusercontent.com/ublue-os/uupd/refs/heads/main/uupd-manual.service | install -Dm644 /dev/stdin "/usr/lib/systemd/system/uupd-manual.service"

echo "Fetching uupd.rules..."
curl -sL https://raw.githubusercontent.com/ublue-os/uupd/refs/heads/main/uupd.rules | install -Dm644 /dev/stdin "/etc/polkit-1/rules.d/uupd.rules"